// Prisma schema - Gestion Restaurant MVP
// Valeurs catégorielles (role, status, unit, payment_method, category, etc.) stockées en String
// et validées par Zod côté API afin de conserver les libellés français accentués du cahier des charges.
// Montants en Int (FCFA, sans centimes - cf. §13.3) ; quantités en Float.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Restaurant = tenant. Toutes les entités opérationnelles lui appartiennent via restaurantId.
model Restaurant {
  id        Int      @id @default(autoincrement())
  name      String   @db.VarChar(120)
  slug      String   @unique @db.VarChar(140)
  status    String   @default("active") @db.VarChar(20) // 'pending' | 'active' | 'suspended'
  createdAt DateTime @default(now()) @map("created_at")

  activatedAt       DateTime? @map("activated_at")
  rejectedAt        DateTime? @map("rejected_at")
  rejectedReason    String?   @map("rejected_reason") @db.Text
  suspendedAt       DateTime? @map("suspended_at")
  suspendedReason   String?   @map("suspended_reason") @db.Text

  memberships      Membership[]
  users            User[] // utilisateurs dont c'est le restaurant "principal" historique (nullable)
  dishes           Dish[]
  stockItems       StockItem[]
  orders           Order[]
  tables           Table[]
  cashSessions     CashSession[]
  reservations     Reservation[]
  promotions       Promotion[]
  expenses         Expense[]
  employees        Employee[]
  suppliers        Supplier[]
  purchases        Purchase[]
  inventories      Inventory[]
  notifications    Notification[]
  auditLogs        AuditLog[]
  appSettings      AppSetting[]
  stockMovements   StockMovement[]
  invitations      Invitation[]
  catalogRequests  CatalogRequest[]

  @@map("restaurants")
}

// Appartenance d'un utilisateur à un restaurant, avec son rôle dans ce restaurant.
model Membership {
  id           Int      @id @default(autoincrement())
  userId       Int      @map("user_id")
  restaurantId Int      @map("restaurant_id")
  role         String   @db.VarChar(20) // 'propriétaire' | 'administrateur' | 'caissier' | 'cuisinier' | 'serveur'
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")

  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Cascade)

  @@unique([userId, restaurantId])
  @@index([restaurantId], map: "idx_memberships_restaurant")
  @@map("memberships")
}

model Invitation {
  id           Int       @id @default(autoincrement())
  restaurantId Int       @map("restaurant_id")
  email        String    @db.VarChar(190)
  role         String    @db.VarChar(20)
  token        String    @unique @db.VarChar(64)
  status       String    @default("pending") @db.VarChar(20)
  expiresAt    DateTime  @map("expires_at")
  createdBy    Int?      @map("created_by")
  acceptedAt   DateTime? @map("accepted_at")
  revokedAt    DateTime? @map("revoked_at")
  createdAt    DateTime  @default(now()) @map("created_at")

  restaurant Restaurant @relation(fields: [restaurantId], references: [id], onDelete: Restrict)
  creator    User?      @relation("InvitationCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([restaurantId, status], map: "idx_invitations_restaurant_status")
  @@index([email, status], map: "idx_invitations_email_status")
  @@map("invitations")
}

model User {
  id           Int       @id @default(autoincrement())
  email        String    @unique @db.VarChar(190)
  passwordHash String    @map("password_hash") @db.VarChar(255)
  displayName  String?   @map("display_name") @db.VarChar(80)
  isSuperAdmin Boolean   @default(false) @map("is_super_admin")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  lastLogin    DateTime? @map("last_login")

  // Restaurant "principal" historique (nullable, info ; le contexte vient des memberships).
  restaurantId Int?         @map("restaurant_id")
  restaurant   Restaurant?  @relation(fields: [restaurantId], references: [id])
  memberships  Membership[]

  createdOrders      Order[]            @relation("CreatedOrders")
  servedOrders       Order[]            @relation("ServerOrders")
  cancelledOrders    Order[]            @relation("CancelledOrders")
  refundedOrders     Order[]            @relation("RefundedOrders")
  stockMovements     StockMovement[]
  notificationReads  NotificationRead[]
  cashSessions       CashSession[]      @relation("CashierSessions")
  closedSessions     CashSession[]      @relation("ClosedSessions")
  auditLogs          AuditLog[]
  purchases          Purchase[]
  inventories        Inventory[]
  reservations       Reservation[]
  employee           Employee?
  expenses           Expense[]
  invitationsCreated      Invitation[]     @relation("InvitationCreator")
  articlesCreated         Article[]        @relation("ArticleCreator")
  catalogRequestsCreated  CatalogRequest[] @relation("CatalogRequestCreator")

  @@map("users")
}

// Dépense d'exploitation (charges générales, hors achats fournisseurs/stock) (§ gestion).
// Registre comptable simple : n'impacte pas la caisse. Réservé à l'administrateur.
model Expense {
  id            Int      @id @default(autoincrement())
  label         String   @db.VarChar(120)
  category      String   @db.VarChar(30)
  amount        Int
  expenseDate   DateTime @map("expense_date")
  paymentMethod String?  @map("payment_method") @db.VarChar(20)
  note          String?  @db.Text
  createdBy     Int?     @map("created_by")
  createdAt     DateTime @default(now()) @map("created_at")
  restaurantId  Int?     @map("restaurant_id")

  creator    User?       @relation(fields: [createdBy], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([expenseDate], map: "idx_expenses_date")
  @@index([category], map: "idx_expenses_category")
  @@index([restaurantId], map: "idx_expenses_restaurant")
  @@map("expenses")
}

// Fiche employé (RH) : distincte du compte de connexion (User), reliée optionnellement via userId.
// Gère aussi le personnel sans accès à l'app. Données sensibles (salaire) : routes réservées à l'admin.
model Employee {
  id               Int       @id @default(autoincrement())
  // Identité & contact
  firstName        String    @map("first_name") @db.VarChar(50)
  lastName         String    @map("last_name") @db.VarChar(50)
  phone            String?   @db.VarChar(30)
  email            String?   @db.VarChar(100)
  address          String?   @db.Text
  photoUrl         String?   @map("photo_url") @db.Text
  // Contrat
  position         String?   @db.VarChar(60)
  contractType     String?   @map("contract_type") @db.VarChar(20)
  hireDate         DateTime? @map("hire_date")
  endDate          DateTime? @map("end_date")
  // Rémunération (FCFA, sans centimes)
  salary           Int?
  salaryPeriod     String?   @map("salary_period") @db.VarChar(15)
  paymentMethod    String?   @map("payment_method") @db.VarChar(20)
  // RH & urgence
  emergencyContact String?   @map("emergency_contact") @db.VarChar(100)
  emergencyPhone   String?   @map("emergency_phone") @db.VarChar(30)
  idNumber         String?   @map("id_number") @db.VarChar(50)
  notes            String?   @db.Text
  // Statut & lien compte
  isActive         Boolean   @default(true) @map("is_active")
  userId           Int?      @unique @map("user_id")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")
  restaurantId     Int?      @map("restaurant_id")

  user       User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([isActive], map: "idx_employees_active")
  @@index([restaurantId], map: "idx_employees_restaurant")
  @@map("employees")
}

model StockItem {
  id               Int      @id @default(autoincrement())
  name             String   @db.VarChar(100)
  quantity         Float    @default(0)
  baselineQuantity Float?   @map("baseline_quantity")
  unit             String   @db.VarChar(20)
  // Coût d'achat par unité (FCFA). Float pour gérer les coûts au gramme/ml près. Base du coût de revient des plats.
  unitCost         Float    @default(0) @map("unit_cost")
  alertThreshold   Float    @default(10) @map("alert_threshold")
  lastUpdated    DateTime @default(now()) @map("last_updated")
  createdAt      DateTime @default(now()) @map("created_at")
  restaurantId   Int?     @map("restaurant_id")

  dishIngredients    DishIngredient[]
  variantIngredients VariantIngredient[]
  movements          StockMovement[]
  notifications      Notification[]
  purchases          Purchase[]
  inventoryLines     InventoryLine[]
  restaurant         Restaurant?         @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([quantity, alertThreshold], map: "idx_stock_items_alert")
  @@index([restaurantId], map: "idx_stock_items_restaurant")
  @@map("stock_items")
}

model Dish {
  id              Int      @id @default(autoincrement())
  name            String   @db.VarChar(100)
  description     String?  @db.Text
  price           Int
  // Mode de prix : 'fixe' (price appliqué tel quel) ou 'libre' (caissier saisit un montant entre priceMin et priceMax ; price sert de défaut suggéré).
  priceType       String   @default("fixe") @map("price_type") @db.VarChar(10)
  priceMin        Int?     @map("price_min")
  priceMax        Int?     @map("price_max")
  imageUrl        String?  @map("image_url") @db.Text
  isActive        Boolean  @default(true) @map("is_active")
  category        String?  @db.VarChar(50)
  preparationTime Int?     @map("preparation_time")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")
  restaurantId    Int?     @map("restaurant_id")

  ingredients      DishIngredient[]
  variants         DishVariant[]
  orderItems       OrderItem[]
  reservationItems ReservationItem[]
  restaurant       Restaurant?       @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([isActive], map: "idx_dishes_active")
  @@index([restaurantId], map: "idx_dishes_restaurant")
  @@map("dishes")
}

model DishIngredient {
  id             Int   @id @default(autoincrement())
  dishId         Int   @map("dish_id")
  stockItemId    Int   @map("stock_item_id")
  quantityNeeded Float @map("quantity_needed")

  dish      Dish      @relation(fields: [dishId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@unique([dishId, stockItemId])
  @@map("dish_ingredients")
}

// Déclinaison d'un plat (ex. Petit / Grand) avec son propre prix et sa propre recette.
model DishVariant {
  id        Int     @id @default(autoincrement())
  dishId    Int     @map("dish_id")
  name      String  @db.VarChar(50)
  price     Int?
  isActive  Boolean @default(true) @map("is_active")
  sortOrder Int     @default(0) @map("sort_order")

  dish             Dish                @relation(fields: [dishId], references: [id], onDelete: Cascade)
  ingredients      VariantIngredient[]
  orderItems       OrderItem[]
  reservationItems ReservationItem[]

  @@index([dishId], map: "idx_dish_variants_dish")
  @@map("dish_variants")
}

// Recette propre à une variante (§ recette par variante).
model VariantIngredient {
  id             Int   @id @default(autoincrement())
  variantId      Int   @map("variant_id")
  stockItemId    Int   @map("stock_item_id")
  quantityNeeded Float @map("quantity_needed")

  variant   DishVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  stockItem StockItem   @relation(fields: [stockItemId], references: [id], onDelete: Restrict)

  @@unique([variantId, stockItemId])
  @@map("variant_ingredients")
}

model Order {
  id                  Int       @id @default(autoincrement())
  orderNumber         String    @map("order_number") @db.VarChar(20)
  total               Int
  discountAmount      Int       @default(0) @map("discount_amount")
  discountPercent     Float     @default(0) @map("discount_percent")
  finalTotal          Int       @map("final_total")
  // Acompte de réservation déduit lors du règlement de cette commande (l'argent a déjà été encaissé
  // à la réservation). La caisse compte (finalTotal − depositApplied) pour ne pas double-compter.
  depositApplied      Int       @default(0) @map("deposit_applied")
  paymentMethod       String?   @map("payment_method") @db.VarChar(20)
  paymentDetails      Json?     @map("payment_details")
  mobileMoneyProvider String?   @map("mobile_money_provider") @db.VarChar(20)
  cashGiven           Int?      @map("cash_given")
  changeReturned      Int?      @map("change_returned")
  channel             String    @default("sur_place") @db.VarChar(20)
  deliveryPlatform    String?   @map("delivery_platform") @db.VarChar(20)
  customerName        String?   @map("customer_name") @db.VarChar(100)
  customerPhone       String?   @map("customer_phone") @db.VarChar(30)
  taxRate             Float     @default(0) @map("tax_rate")
  taxAmount           Int       @default(0) @map("tax_amount")
  tipAmount           Int       @default(0) @map("tip_amount")
  tipMethod           String?   @map("tip_method") @db.VarChar(20)
  promotionId         Int?      @map("promotion_id")
  promoLabel          String?   @map("promo_label") @db.VarChar(60)
  isPaid              Boolean   @default(false) @map("is_paid")
  paidAt              DateTime? @map("paid_at")
  status              String    @default("commandée") @db.VarChar(30)
  tableId             Int?      @map("table_id")
  serverId            Int?      @map("server_id")
  createdBy           Int?      @map("created_by")
  cashSessionId       Int?      @map("cash_session_id")
  createdAt           DateTime  @default(now()) @map("created_at")
  preparedAt          DateTime? @map("prepared_at")
  readyAt             DateTime? @map("ready_at")
  servedAt            DateTime? @map("served_at")
  cancelledAt         DateTime? @map("cancelled_at")
  cancelledBy         Int?      @map("cancelled_by")
  cancellationReason  String?   @map("cancellation_reason") @db.Text
  isRefunded          Boolean   @default(false) @map("is_refunded")
  refundedAt          DateTime? @map("refunded_at")
  refundedBy          Int?      @map("refunded_by")
  refundReason        String?   @map("refund_reason") @db.Text
  isSynced            Boolean   @default(false) @map("is_synced")
  restaurantId        Int?      @map("restaurant_id")

  creator        User?           @relation("CreatedOrders", fields: [createdBy], references: [id])
  server         User?           @relation("ServerOrders", fields: [serverId], references: [id])
  canceller      User?           @relation("CancelledOrders", fields: [cancelledBy], references: [id])
  refunder       User?           @relation("RefundedOrders", fields: [refundedBy], references: [id])
  table          Table?          @relation(fields: [tableId], references: [id])
  cashSession    CashSession?    @relation(fields: [cashSessionId], references: [id])
  promotion      Promotion?      @relation(fields: [promotionId], references: [id])
  items          OrderItem[]
  stockMovements StockMovement[]
  notifications  Notification[]
  restaurant     Restaurant?     @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, orderNumber])
  @@index([status], map: "idx_orders_status")
  @@index([createdAt], map: "idx_orders_created_at")
  @@index([orderNumber], map: "idx_orders_number")
  @@index([tableId], map: "idx_orders_table")
  @@index([cashSessionId], map: "idx_orders_cash_session")
  @@index([restaurantId], map: "idx_orders_restaurant")
  @@map("orders")
}

model OrderItem {
  id          Int     @id @default(autoincrement())
  orderId     Int     @map("order_id")
  dishId      Int     @map("dish_id")
  dishName    String  @map("dish_name") @db.VarChar(100)
  dishPrice   Int     @map("dish_price")
  variantId   Int?    @map("variant_id")
  variantName String? @map("variant_name") @db.VarChar(50)
  isOffered   Boolean @default(false) @map("is_offered")
  quantity    Int     @default(1)
  subtotal    Int
  notes       String? @db.Text

  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  dish    Dish         @relation(fields: [dishId], references: [id])
  variant DishVariant? @relation(fields: [variantId], references: [id])

  @@map("order_items")
}

model StockMovement {
  id               Int      @id @default(autoincrement())
  stockItemId      Int      @map("stock_item_id")
  movementType     String   @map("movement_type") @db.VarChar(20)
  quantity         Float
  previousQuantity Float    @map("previous_quantity")
  newQuantity      Float    @map("new_quantity")
  orderId          Int?     @map("order_id")
  cause            String?  @db.VarChar(30)
  note             String?  @db.Text
  createdBy        Int?     @map("created_by")
  createdAt        DateTime @default(now()) @map("created_at")
  restaurantId     Int?     @map("restaurant_id")

  stockItem  StockItem   @relation(fields: [stockItemId], references: [id])
  order      Order?      @relation(fields: [orderId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([restaurantId], map: "idx_stock_movements_restaurant")
  @@map("stock_movements")
}

model Notification {
  id             Int      @id @default(autoincrement())
  userRole       String   @map("user_role") @db.VarChar(20)
  title          String   @db.VarChar(100)
  message        String   @db.Text
  type           String   @db.VarChar(30)
  relatedOrderId Int?     @map("related_order_id")
  relatedStockId Int?     @map("related_stock_id")
  isRead         Boolean  @default(false) @map("is_read")
  createdAt      DateTime @default(now()) @map("created_at")
  restaurantId   Int?     @map("restaurant_id")

  relatedOrder Order?             @relation(fields: [relatedOrderId], references: [id])
  relatedStock StockItem?         @relation(fields: [relatedStockId], references: [id])
  reads        NotificationRead[]
  restaurant   Restaurant?        @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([userRole, isRead], map: "idx_notifications_role")
  @@index([restaurantId], map: "idx_notifications_restaurant")
  @@map("notifications")
}

model NotificationRead {
  id             Int      @id @default(autoincrement())
  notificationId Int      @map("notification_id")
  userId         Int      @map("user_id")
  readAt         DateTime @default(now()) @map("read_at")

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])

  @@unique([notificationId, userId])
  @@map("notification_reads")
}

model AppSetting {
  id           Int      @id @default(autoincrement())
  settingKey   String   @map("setting_key") @db.VarChar(50)
  settingValue String   @map("setting_value") @db.Text
  description  String?  @db.Text
  updatedAt    DateTime @updatedAt @map("updated_at")
  restaurantId Int?     @map("restaurant_id")

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, settingKey])
  @@index([restaurantId], map: "idx_app_settings_restaurant")
  @@map("app_settings")
}

model Table {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(50)
  capacity      Int      @default(4)
  billRequested Boolean  @default(false) @map("bill_requested")
  createdAt     DateTime @default(now()) @map("created_at")
  restaurantId  Int?     @map("restaurant_id")

  orders       Order[]
  reservations Reservation[]
  restaurant   Restaurant?   @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, name])
  @@index([restaurantId], map: "idx_tables_restaurant")
  @@map("tables")
}

// Réservation d'une table (§D).
model Reservation {
  id                   Int       @id @default(autoincrement())
  tableId              Int       @map("table_id")
  customerName         String    @map("customer_name") @db.VarChar(100)
  customerPhone        String?   @map("customer_phone") @db.VarChar(30)
  partySize            Int?      @map("party_size")
  reservedAt           DateTime  @map("reserved_at")
  // Durée réservée du repas en minutes (heure de fin = reservedAt + durationMinutes).
  // La libération de la table ajoute ensuite 30 min de marge client + 30 min de nettoyage (cf. constants.ts).
  durationMinutes      Int       @default(90) @map("duration_minutes")
  // Pré-commande informative : nourriture/boisson réservées à l'avance (cf. hasPreOrder), SANS impact cuisine/stock.
  hasPreOrder          Boolean   @default(false) @map("has_pre_order")
  // Montants (FCFA) : coût total prévu, acompte versé. Le reste à payer = totalAmount - depositAmount (calculé à l'affichage).
  totalAmount          Int       @default(0) @map("total_amount")
  depositAmount        Int       @default(0) @map("deposit_amount")
  depositMethod        String?   @map("deposit_method") @db.VarChar(20)
  depositAt            DateTime? @map("deposit_at")
  // Session de caisse ayant encaissé l'acompte en espèces → compté dans le théorique de caisse.
  depositCashSessionId Int?      @map("deposit_cash_session_id")
  // Statut de paiement : 'aucun' | 'avance' | 'réglé' (dérivé des montants).
  paymentStatus        String    @default("aucun") @map("payment_status") @db.VarChar(15)
  // Acompte appliqué (déduit) lors du règlement de la table → évite de le déduire deux fois.
  depositConsumed      Boolean   @default(false) @map("deposit_consumed")
  // Acompte remboursé au client (ex. annulation) : l'argent ressort, donc retiré du théorique de caisse.
  depositRefunded      Boolean   @default(false) @map("deposit_refunded")
  depositRefundedAt    DateTime? @map("deposit_refunded_at")
  note                 String?   @db.Text
  status               String    @default("active") @db.VarChar(20)
  createdBy            Int?      @map("created_by")
  createdAt            DateTime  @default(now()) @map("created_at")
  restaurantId         Int?      @map("restaurant_id")

  table              Table             @relation(fields: [tableId], references: [id], onDelete: Cascade)
  creator            User?             @relation(fields: [createdBy], references: [id])
  depositCashSession CashSession?      @relation("ReservationDeposits", fields: [depositCashSessionId], references: [id])
  items              ReservationItem[]
  restaurant         Restaurant?       @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([tableId, status], map: "idx_reservations_table")
  @@index([reservedAt], map: "idx_reservations_date")
  @@index([restaurantId], map: "idx_reservations_restaurant")
  @@map("reservations")
}

// Plat/boisson pré-commandé sur une réservation. Purement informatif (prix figé à l'ajout) :
// aucune incidence cuisine ni stock tant que les clients ne sont pas arrivés.
model ReservationItem {
  id            Int     @id @default(autoincrement())
  reservationId Int     @map("reservation_id")
  dishId        Int?    @map("dish_id")
  dishName      String  @map("dish_name") @db.VarChar(100)
  dishPrice     Int     @map("dish_price")
  variantId     Int?    @map("variant_id")
  variantName   String? @map("variant_name") @db.VarChar(50)
  quantity      Int     @default(1)
  subtotal      Int
  notes         String? @db.Text

  reservation Reservation  @relation(fields: [reservationId], references: [id], onDelete: Cascade)
  dish        Dish?        @relation(fields: [dishId], references: [id], onDelete: SetNull)
  variant     DishVariant? @relation(fields: [variantId], references: [id], onDelete: SetNull)

  @@index([reservationId], map: "idx_reservation_items_res")
  @@map("reservation_items")
}

// Session de caisse : ouverture/fermeture avec fond, total théorique/réel et écart (§B).
model CashSession {
  id                Int       @id @default(autoincrement())
  cashierId         Int       @map("cashier_id")
  openingFloat      Int       @map("opening_float")
  status            String    @default("ouverte") @db.VarChar(20)
  openedAt          DateTime  @default(now()) @map("opened_at")
  closedAt          DateTime? @map("closed_at")
  closedBy          Int?      @map("closed_by")
  expectedCash      Int?      @map("expected_cash")
  countedCash       Int?      @map("counted_cash")
  discrepancy       Int?
  discrepancyReason String?   @map("discrepancy_reason") @db.Text
  notes             String?   @db.Text
  restaurantId      Int?      @map("restaurant_id")

  cashier             User          @relation("CashierSessions", fields: [cashierId], references: [id])
  closer              User?         @relation("ClosedSessions", fields: [closedBy], references: [id])
  orders              Order[]
  reservationDeposits Reservation[] @relation("ReservationDeposits")
  restaurant          Restaurant?   @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([cashierId, status], map: "idx_cash_sessions_cashier")
  @@index([restaurantId], map: "idx_cash_sessions_restaurant")
  @@map("cash_sessions")
}

// Promotions : happy hour (auto, par plage horaire) ou coupon (code) (§F).
model Promotion {
  id            Int      @id @default(autoincrement())
  name          String   @db.VarChar(100)
  kind          String   @db.VarChar(20) // 'happy_hour' | 'coupon'
  discountType  String   @map("discount_type") @db.VarChar(10) // 'percent' | 'amount'
  discountValue Int      @map("discount_value")
  isActive      Boolean  @default(true) @map("is_active")
  startHour     Int?     @map("start_hour")
  endHour       Int?     @map("end_hour")
  days          String?  @db.VarChar(30) // jours (CSV "1,2,3", 1=lundi) ; null = tous les jours
  code          String?  @db.VarChar(30)
  maxUses       Int?     @map("max_uses")
  usedCount     Int      @default(0) @map("used_count")
  createdAt     DateTime @default(now()) @map("created_at")
  restaurantId  Int?     @map("restaurant_id")

  orders     Order[]
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@unique([restaurantId, code])
  @@index([restaurantId], map: "idx_promotions_restaurant")
  @@map("promotions")
}

// Journal d'actions sensibles : qui a fait quoi, quand (§C).
model AuditLog {
  id           Int      @id @default(autoincrement())
  userId       Int?     @map("user_id")
  action       String   @db.VarChar(40)
  entityType   String   @map("entity_type") @db.VarChar(30)
  entityId     Int?     @map("entity_id")
  details      Json?
  createdAt    DateTime @default(now()) @map("created_at")
  restaurantId Int?     @map("restaurant_id")

  user       User?       @relation(fields: [userId], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([action], map: "idx_audit_action")
  @@index([createdAt], map: "idx_audit_created_at")
  @@index([restaurantId], map: "idx_audit_logs_restaurant")
  @@map("audit_logs")
}

model SyncQueue {
  id         Int       @id @default(autoincrement())
  actionType String    @map("action_type") @db.VarChar(50)
  tableName  String    @map("table_name") @db.VarChar(50)
  recordId   Int?      @map("record_id")
  data       Json
  createdAt  DateTime  @default(now()) @map("created_at")
  syncedAt   DateTime? @map("synced_at")
  isSynced   Boolean   @default(false) @map("is_synced")

  @@map("sync_queue")
}

// Fournisseur (§E).
model Supplier {
  id           Int      @id @default(autoincrement())
  name         String   @db.VarChar(100)
  phone        String?  @db.VarChar(30)
  contact      String?  @db.VarChar(100)
  note         String?  @db.Text
  createdAt    DateTime @default(now()) @map("created_at")
  restaurantId Int?     @map("restaurant_id")

  purchases  Purchase[]
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([restaurantId], map: "idx_suppliers_restaurant")
  @@map("suppliers")
}

// Achat fournisseur (un article par achat) ; suivi dette/échéance (§E).
model Purchase {
  id           Int       @id @default(autoincrement())
  supplierId   Int       @map("supplier_id")
  stockItemId  Int       @map("stock_item_id")
  quantity     Float
  unitPrice    Int       @map("unit_price")
  totalPrice   Int       @map("total_price")
  dueDate      DateTime? @map("due_date")
  isPaid       Boolean   @default(false) @map("is_paid")
  paidAt       DateTime? @map("paid_at")
  note         String?   @db.Text
  createdBy    Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  restaurantId Int?      @map("restaurant_id")

  supplier   Supplier    @relation(fields: [supplierId], references: [id], onDelete: Cascade)
  stockItem  StockItem   @relation(fields: [stockItemId], references: [id])
  creator    User?       @relation(fields: [createdBy], references: [id])
  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([supplierId], map: "idx_purchases_supplier")
  @@index([restaurantId], map: "idx_purchases_restaurant")
  @@map("purchases")
}

// Session d'inventaire : théorique (système) vs réel (compté) (§C).
model Inventory {
  id           Int       @id @default(autoincrement())
  type         String    @db.VarChar(20)
  status       String    @default("en_cours") @db.VarChar(20)
  note         String?   @db.Text
  createdBy    Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  validatedAt  DateTime? @map("validated_at")
  restaurantId Int?      @map("restaurant_id")

  creator    User?           @relation(fields: [createdBy], references: [id])
  lines      InventoryLine[]
  restaurant Restaurant?     @relation(fields: [restaurantId], references: [id], onDelete: Restrict)

  @@index([restaurantId], map: "idx_inventories_restaurant")
  @@map("inventories")
}

model InventoryLine {
  id             Int    @id @default(autoincrement())
  inventoryId    Int    @map("inventory_id")
  stockItemId    Int    @map("stock_item_id")
  theoreticalQty Float  @map("theoretical_qty")
  countedQty     Float? @map("counted_qty")

  inventory Inventory @relation(fields: [inventoryId], references: [id], onDelete: Cascade)
  stockItem StockItem @relation(fields: [stockItemId], references: [id])

  @@unique([inventoryId, stockItemId])
  @@map("inventory_lines")
}

// Article de blog ou success story — contenu plateforme, non scopé par tenant.
// Géré par le super-admin, lu publiquement.
model Article {
  id          Int       @id @default(autoincrement())
  type        String    @default("blog") @db.VarChar(20)   // 'blog' | 'success_story'
  title       String    @db.VarChar(200)
  slug        String    @unique @db.VarChar(220)
  excerpt     String?   @db.Text
  content     String    @db.Text                            // markdown
  coverUrl    String?   @map("cover_url") @db.Text          // data URL OU URL https externe
  category    String?   @db.VarChar(50)                     // pour blog : gestion/marketing/strategie/cuisine-africaine...
  authorName  String?   @map("author_name") @db.VarChar(100)
  featuredName String?  @map("featured_name") @db.VarChar(120) // success story : nom du resto/personne
  status      String    @default("draft") @db.VarChar(20)   // 'draft' | 'published'
  publishedAt DateTime? @map("published_at")
  createdBy   Int?      @map("created_by")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  creator User? @relation("ArticleCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([type, status], map: "idx_articles_type_status")
  @@index([slug], map: "idx_articles_slug")
  @@map("articles")
}

// Demande de référencement d'un restaurant sur une plateforme externe (Yango Food, Glovo, etc.)
// Scopée par tenant (restaurantId). Traitée par le super-admin.
model CatalogRequest {
  id           Int       @id @default(autoincrement())
  restaurantId Int?      @map("restaurant_id")
  platforms    String[]
  message      String?   @db.Text
  status       String    @default("pending") @db.VarChar(20)
  adminNote    String?   @map("admin_note") @db.Text
  createdBy    Int?      @map("created_by")
  createdAt    DateTime  @default(now()) @map("created_at")
  processedAt  DateTime? @map("processed_at")

  restaurant Restaurant? @relation(fields: [restaurantId], references: [id], onDelete: Cascade)
  creator    User?       @relation("CatalogRequestCreator", fields: [createdBy], references: [id], onDelete: SetNull)

  @@index([restaurantId, status], map: "idx_catalog_requests_restaurant_status")
  @@index([status], map: "idx_catalog_requests_status")
  @@map("catalog_requests")
}
