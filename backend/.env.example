# Server
PORT=3000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://restaurant:restaurant@localhost:5432/restaurant_db?schema=public"

# JWT
JWT_SECRET=change_me_super_secret
JWT_EXPIRES_IN=24h
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_REFRESH_EXPIRES_IN=7d

# CORS
CORS_ORIGIN=http://localhost:5173

# Super-admin plateforme (seed)
SUPERADMIN_EMAIL=superadmin@plateforme.local
SUPERADMIN_PASSWORD=change_me

# URL de base (liens d'invitation, P2)
APP_BASE_URL=http://localhost:5173
